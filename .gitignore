Vagrantfile

#---------------------------------------------------------
# Temporary & Writable Files (Global Pattern)
#---------------------------------------------------------
# Menggunakan **/ agar mencakup 'writable/' maupun 'public/writable/'
**/writable/cache/*
**/writable/logs/*
**/writable/session/*
**/writable/debugbar/*
**/writable/uploads/*
**/writable/temp/*

# Jangan abaikan file placeholder agar struktur folder tetap ada di Git
!**/writable/**/index.html
!**/writable/**/.htaccess

# File log PHP umum
php_errors.log

#---------------------------------------------------------
# Composer & Dependencies
#---------------------------------------------------------
vendor/

